# Загальні налаштування
APP_URL=https://your-domain.com

# База даних
DB_HOST=127.0.0.1
DB_NAME=YOUR_DATABASE_NAME
DB_USER=root
DB_PASS=YOUR_DATABASE_PASSWORD

# Telegram Боти
# Токен для оплати через Telegram Stars
TELEGRAM_BOT_TOKEN="YOUR_PAYMENT_BOT_TOKEN"
# Токен для віджета авторизації через Telegram
TELEGRAM_LOGIN_BOT_TOKEN="YOUR_LOGIN_BOT_TOKEN"

# Donatello (Фіатні платежі)
DONATELLO_TOKEN="YOUR_DONATELLO_API_KEY"
DONATELLO_URL="https://donatello.to/YOUR_PAGE"

# GitHub OAuth
GITHUB_CLIENT_ID="YOUR_GITHUB_CLIENT_ID"
GITHUB_CLIENT_SECRET="YOUR_GITHUB_CLIENT_SECRET"

# WebAuthn / Passkey
WEBAUTHN_RP_ID=your-domain.com
WEBAUTHN_ORIGIN=https://your-domain.com

# Безпека
# Секрет для HMAC підпису кукі "Запам'ятати мене"
COOKIE_SECRET="YOUR_RANDOM_SECURE_SECRET_KEY"
